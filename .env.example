# ============================================================
# Floci Management Console — Environment Variables
# Copy to .env and fill in your values before running.
# ============================================================

# PostgreSQL
POSTGRES_PASSWORD=floci_secret_change_me

# Backend Security
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_64_char_hex_string

# Encryption key for Floci instance secret_key field at rest
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace_with_fernet_key

# First Superadmin (created on first startup if no users exist)
FIRST_SUPERADMIN_EMAIL=admin@yourdomain.com
FIRST_SUPERADMIN_PASSWORD=ChangeMe123!

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# CORS (comma-separated list of allowed origins)
BACKEND_CORS_ORIGINS=http://localhost:3000
